---
import Base from "~/layouts/Base.astro";
---
<Base
  wide
  title="个税计算器"
  description="覆盖工资月度预扣（累计预扣预缴法）、年度汇算、年终奖（单独/并入对比）、劳务报酬/稿酬/特许权使用费、个体经营所得的全场景个税计算。基于 2026 年现行税率表。"
>
  <h1 style="margin-bottom:4px;">个税计算器</h1>
  <p style="font-size:13px;margin:0 0 8px;">
    覆盖月度预扣、年度汇算、年终奖、劳务稿酬、经营所得 5 大场景。数据本地处理，不上传。
    入门：<a href="/guides/tax-deductions">专项附加扣除指南</a> · <a href="/tax-rate-tables">税率表</a>
  </p>

  <div class="tabs" role="tablist">
    <button data-tab="monthly" role="tab" aria-selected="true">月度预扣</button>
    <button data-tab="annual" role="tab" aria-selected="false">年度汇算</button>
    <button data-tab="bonus" role="tab" aria-selected="false">年终奖对比</button>
    <button data-tab="incidental" role="tab" aria-selected="false">劳务/稿酬</button>
    <button data-tab="business" role="tab" aria-selected="false">经营所得</button>
  </div>

  {/* ==================== Tab 1: 月度预扣 ==================== */}
  <section class="tab-panel active" data-panel="monthly">
    <div class="split">
      <div class="col-input">
        <div class="card compact">
          <h3>收入与五险一金</h3>
          <div class="form-grid">
            <label>月税前工资（元）<input id="m-gross" type="number" min="0" max="100000000" step="100" value="20000" /></label>
            <label>月个人五险一金<input id="m-social" type="number" min="0" max="100000000" step="100" value="3000" /></label>
            <label>月其他扣除（年金等）<input id="m-other" type="number" min="0" max="100000000" step="100" value="0" /></label>
          </div>
          <h3 style="margin-top:12px;">专项附加扣除（每月）</h3>
          <div class="form-grid">
            <label>子女教育（元/月）<input id="m-children" type="number" min="0" max="20000" step="100" value="0" /><small style="color:var(--c-text-soft);font-size:11px;display:block;margin-top:2px;">每孩 2000 元/月，N 个孩填 N×2000</small></label>
            <label>婴幼儿照护（元/月）<input id="m-infant" type="number" min="0" max="20000" step="100" value="0" /><small style="color:var(--c-text-soft);font-size:11px;display:block;margin-top:2px;">3 岁以下每孩 2000，N 个孩填 N×2000</small></label>
            <label>继续教育（元/月）<input id="m-edu" type="number" min="0" max="20000" step="100" value="0" /><small style="color:var(--c-text-soft);font-size:11px;display:block;margin-top:2px;">学历教育 400，职业技能不在此处填写</small></label>
            <label>住房贷款利息（元/月）<input id="m-loan" type="number" min="0" max="20000" step="100" value="0" /><small style="color:var(--c-text-soft);font-size:11px;display:block;margin-top:2px;">首套住房 1000，二套不享受</small></label>
            <label>住房租金（元/月）<input id="m-rent" type="number" min="0" max="20000" step="100" value="0" /><small style="color:var(--c-text-soft);font-size:11px;display:block;margin-top:2px;">北上广深 1500 / 省会城市 1100 / 其他 800</small></label>
            <label>赡养老人（元/月）<input id="m-elder" type="number" min="0" max="20000" step="100" value="0" /><small style="color:var(--c-text-soft);font-size:11px;display:block;margin-top:2px;">独生子女 3000，非独生分摊每人 ≤1500</small></label>
          </div>
          <p class="error-msg" id="m-error" style="color:var(--c-danger);margin:8px 0 0;min-height:18px;font-size:12px;"></p>
        </div>
      </div>

      <div class="col-result">
        <div class="card compact highlight">
          <div style="font-size:12px;color:var(--c-text-soft);">全年税后到手</div>
          <div style="font-size:24px;font-weight:600;color:var(--c-success);" id="m-total-net">—</div>
        </div>
        <div class="card compact">
          <div class="kv-grid">
            <div><div class="label">每月专项附加</div><div class="value" id="m-special-sum">—</div></div>
            <div><div class="label">每月减除合计</div><div class="value" id="m-deduct-sum">—</div></div>
            <div><div class="label">全年税前</div><div class="value" id="m-total-gross">—</div></div>
            <div><div class="label">全年应缴税</div><div class="value" id="m-total-tax" style="color:var(--c-danger);">—</div></div>
            <div style="grid-column:1/-1;"><div class="label">全年综合税率</div><div class="value" id="m-eff-rate">—</div></div>
          </div>
        </div>
        <details class="card compact">
          <summary style="cursor:pointer;font-weight:600;font-size:14px;">12 个月预扣明细</summary>
          <div style="overflow-x:auto;max-height:280px;overflow-y:auto;margin-top:8px;">
            <table id="m-table">
              <thead><tr><th>月</th><th>累计应纳</th><th>累计税</th><th>本月预扣</th><th>本月到手</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </section>

  {/* ==================== Tab 2: 年度汇算 ==================== */}
  <section class="tab-panel" data-panel="annual">
    <div class="split">
      <div class="col-input">
        <div class="card compact">
          <h3>综合所得收入（年度，税前）</h3>
          <div class="form-grid">
            <label>工资薪金合计<input id="y-salary" type="number" min="0" max="100000000" step="1000" value="240000" /></label>
            <label>劳务报酬合计（80% 计入）<input id="y-labor" type="number" min="0" max="100000000" step="1000" value="0" /></label>
            <label>稿酬合计（56% 计入）<input id="y-author" type="number" min="0" max="100000000" step="1000" value="0" /></label>
            <label>特许权使用费合计（80%）<input id="y-royalty" type="number" min="0" max="100000000" step="1000" value="0" /></label>
          </div>
          <h3 style="margin-top:12px;">扣除（年度）</h3>
          <div class="form-grid">
            <label>五险一金（个人部分）<input id="y-social" type="number" min="0" max="100000000" step="1000" value="36000" /></label>
            <label>专项附加扣除合计<input id="y-special" type="number" min="0" max="100000000" step="1000" value="14400" /></label>
            <label>其他扣除（年金等）<input id="y-other" type="number" min="0" max="100000000" step="1000" value="0" /></label>
            <label>公益慈善捐赠<input id="y-charity" type="number" min="0" max="100000000" step="1000" value="0" /></label>
          </div>
          <h3 style="margin-top:12px;">已预缴</h3>
          <div class="form-grid">
            <label>全年已预扣预缴税额<input id="y-withheld" type="number" min="0" max="100000000" step="100" value="0" /></label>
          </div>
          <p class="error-msg" id="y-error" style="color:var(--c-danger);margin:8px 0 0;min-height:18px;font-size:12px;"></p>
        </div>
      </div>

      <div class="col-result">
        <div class="card compact highlight">
          <div style="font-size:12px;color:var(--c-text-soft);">应退（-）/ 应补（+）</div>
          <div style="font-size:24px;font-weight:600;color:var(--c-accent);" id="y-refund">—</div>
        </div>
        <div class="card compact">
          <div class="kv-grid">
            <div><div class="label">综合所得收入额</div><div class="value" id="y-income">—</div></div>
            <div><div class="label">总扣除</div><div class="value" id="y-deduct">—</div></div>
            <div><div class="label">应纳税所得额</div><div class="value" id="y-taxable">—</div></div>
            <div><div class="label">适用税率</div><div class="value" id="y-rate">—</div></div>
            <div style="grid-column:1/-1;"><div class="label">全年应纳税额</div><div class="value" id="y-due" style="color:var(--c-danger);">—</div></div>
          </div>
          <p style="font-size:12px;margin:8px 0 0;">汇算时间：次年 3-6 月。"应退"代表预扣多了可退税。</p>
        </div>
      </div>
    </div>
  </section>

  {/* ==================== Tab 3: 年终奖对比 ==================== */}
  <section class="tab-panel" data-panel="bonus">
    <div class="split">
      <div class="col-input">
        <div class="card compact">
          <h3>输入</h3>
          <div class="form-grid">
            <label>年终奖金额（元）<input id="b-bonus" type="number" min="0" max="100000000" step="1000" value="50000" /></label>
            <label>本年度综合应纳税所得额<br/>（不含年终奖）<input id="b-base" type="number" min="0" max="100000000" step="1000" value="138000" /></label>
          </div>
          <p style="font-size:12px;margin:8px 0 0;">
            综合应纳税所得额 = 全年工资 − 60000 − 全年社保 − 专项附加扣除 − 其他。可在"年度汇算"算出。
          </p>
          <p class="error-msg" id="b-error" style="color:var(--c-danger);margin:8px 0 0;min-height:18px;font-size:12px;"></p>
        </div>
      </div>

      <div class="col-result">
        <div class="card compact highlight">
          <div style="font-size:12px;color:var(--c-text-soft);">推荐方案</div>
          <div style="font-size:22px;font-weight:600;color:var(--c-accent);" id="b-recommend">—</div>
          <div style="font-size:12px;color:var(--c-text-soft);margin-top:4px;" id="b-saving"></div>
        </div>
        <div class="card compact">
          <div style="font-weight:600;font-size:14px;margin-bottom:6px;">A：单独计税（月度税率表）</div>
          <div class="kv-grid">
            <div><div class="label">应纳税额</div><div class="value" id="b-sep-tax">—</div></div>
            <div><div class="label">适用税率</div><div class="value" id="b-sep-rate">—</div></div>
          </div>
        </div>
        <div class="card compact">
          <div style="font-weight:600;font-size:14px;margin-bottom:6px;">B：并入综合所得</div>
          <div class="kv-grid">
            <div><div class="label">奖金税额增量</div><div class="value" id="b-com-inc">—</div></div>
            <div><div class="label">适用税率</div><div class="value" id="b-com-rate">—</div></div>
            <div style="grid-column:1/-1;"><div class="label">合计应纳税</div><div class="value" id="b-com-tax">—</div></div>
          </div>
        </div>
        <p style="font-size:12px;margin:8px 0 0;color:var(--c-danger);">
          ⚠️ 年终奖陷阱：36000→36001 元，单独计税从 1080→3390，多 1 元多税 2310 元。
        </p>
      </div>
    </div>
  </section>

  {/* ==================== Tab 4: 劳务/稿酬/特许权 ==================== */}
  <section class="tab-panel" data-panel="incidental">
    <div class="split">
      <div class="col-input">
        <div class="card compact">
          <h3>输入</h3>
          <div class="form-grid">
            <label>本次税前收入（元）<input id="i-amount" type="number" min="0" max="10000000" step="100" value="10000" /></label>
          </div>
          <p class="error-msg" id="i-error" style="color:var(--c-danger);margin:8px 0 0;min-height:18px;font-size:12px;"></p>
          <div style="margin-top:10px;">
            <div style="font-size:13px;color:var(--c-text-soft);margin-bottom:4px;">所得类型</div>
            <div class="btn-row">
              <input type="radio" name="i-type" id="i-labor" value="labor" checked />
              <label for="i-labor">劳务</label>
              <input type="radio" name="i-type" id="i-author" value="author" />
              <label for="i-author">稿酬</label>
              <input type="radio" name="i-type" id="i-royalty" value="royalty" />
              <label for="i-royalty">特许权</label>
            </div>
          </div>
          <p style="font-size:12px;margin:10px 0 0;">
            预扣不等于最终税额，年度汇算时并入综合所得，可能多退少补。
          </p>
        </div>
      </div>

      <div class="col-result">
        <div class="card compact highlight">
          <div style="font-size:12px;color:var(--c-text-soft);">本次到手</div>
          <div style="font-size:22px;font-weight:600;color:var(--c-success);" id="i-net">—</div>
        </div>
        <div class="card compact">
          <div class="kv-grid">
            <div><div class="label">应纳税所得</div><div class="value" id="i-taxable">—</div></div>
            <div><div class="label">预扣率</div><div class="value" id="i-rate">—</div></div>
            <div><div class="label">单次预扣税</div><div class="value" id="i-tax" style="color:var(--c-danger);">—</div></div>
            <div><div class="label">年度并入综合</div><div class="value" id="i-annual">—</div></div>
          </div>
        </div>
        <details class="card compact">
          <summary style="cursor:pointer;font-weight:600;font-size:13px;">预扣率说明</summary>
          <p style="font-size:12px;margin:6px 0 0;">
            <strong>劳务报酬</strong>：≤2万 20% / 2-5万 30%（速扣 2000）/ &gt;5万 40%（速扣 7000）。<br/>
            <strong>稿酬</strong>：减除费用 ×70% 后按 20% 预扣。<br/>
            <strong>特许权</strong>：减除费用后按 20% 预扣。<br/>
            减除费用：单次≤4000 减 800；&gt;4000 减 20%。
          </p>
        </details>
      </div>
    </div>
  </section>

  {/* ==================== Tab 5: 经营所得 ==================== */}
  <section class="tab-panel" data-panel="business">
    <div class="split">
      <div class="col-input">
        <div class="card compact">
          <h3>输入</h3>
          <div class="form-grid">
            <label>年总收入（元）<input id="o-revenue" type="number" min="0" max="100000000" step="1000" value="500000" /></label>
            <label>年总成本费用<input id="o-costs" type="number" min="0" max="100000000" step="1000" value="200000" /></label>
            <label>其他可扣除（公益等）<input id="o-other" type="number" min="0" max="100000000" step="1000" value="0" /></label>
            <label>本年实际经营月数<input id="o-months" type="number" min="1" max="12" step="1" value="12" /></label>
          </div>
          <p style="font-size:12px;margin:8px 0 0;">业主本人享受 5000/月起征点，按经营月数折算。</p>
          <p class="error-msg" id="o-error" style="color:var(--c-danger);margin:8px 0 0;min-height:18px;font-size:12px;"></p>
        </div>
      </div>

      <div class="col-result">
        <div class="card compact highlight">
          <div style="font-size:12px;color:var(--c-text-soft);">应纳税额</div>
          <div style="font-size:24px;font-weight:600;color:var(--c-danger);" id="o-tax">—</div>
        </div>
        <div class="card compact">
          <div class="kv-grid">
            <div><div class="label">应纳税所得</div><div class="value" id="o-taxable">—</div></div>
            <div><div class="label">适用税率</div><div class="value" id="o-rate">—</div></div>
            <div style="grid-column:1/-1;"><div class="label">速算扣除数</div><div class="value" id="o-quick">—</div></div>
          </div>
          <p style="font-size:12px;margin:8px 0 0;">5%-35% 五级超额累进，不并入综合所得。</p>
        </div>
      </div>
    </div>
  </section>

  <details class="card compact" style="margin-top:16px;">
    <summary style="cursor:pointer;font-weight:600;font-size:14px;">计算口径说明</summary>
    <ul style="font-size:13px;color:var(--c-text-soft);margin:8px 0 0;">
    <li>累计预扣预缴法（2019 年起）：每月按"截至当月累计应纳税所得额"查表算累计税，减去前期已预扣，得到本月预扣</li>
    <li>专项附加扣除标准：以 2023-08 调整后金额为准（子女教育/婴幼儿照护各 2000、独生赡养老人 3000）</li>
    <li>年终奖单独计税政策延续至 2027 年底，之后或并入综合所得</li>
    <li>劳务报酬等并入年度汇算后，可能补退；高收入劳务收入往往年度税额低于已预扣</li>
    <li>本计算器不处理：股权激励、解除劳动关系一次性补偿、退休金等特殊场景，请咨询专业税务顾问</li>
    <li>结果仅供参考，最终以税务机关核定为准</li>
  </ul>
  </details>

  <script>
    import {
      calcUniformYear,
      calcAnnualSettlement,
      calcAnnualBonus,
      calcIncidentalPrewith,
      calcBusinessIncome,
      fmtCny2,
      type IncidentalIncomeType,
    } from "~/lib/income-tax";

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const cny = (n: number) => `¥${fmtCny2(n)}`;
    const num = (id: string) => Number($<HTMLInputElement>(id).value) || 0;

    // Tab switch
    const tabs = document.querySelectorAll<HTMLButtonElement>(".tabs button[data-tab]");
    const panels = document.querySelectorAll<HTMLElement>(".tab-panel[data-panel]");
    tabs.forEach((t) =>
      t.addEventListener("click", () => {
        tabs.forEach((x) => x.setAttribute("aria-selected", "false"));
        t.setAttribute("aria-selected", "true");
        panels.forEach((p) =>
          p.classList.toggle("active", p.dataset.panel === t.dataset.tab),
        );
      }),
    );

    // ---------- Tab 1: 月度预扣 ----------
    function renderMonthly(): void {
      const monthlyGross = num("m-gross");
      const monthlySocial = num("m-social");
      const monthlyOther = num("m-other");
      const monthlySpecial = {
        childrenEducation: num("m-children"),
        infantCare: num("m-infant"),
        continuingEducation: num("m-edu"),
        housingLoanInterest: num("m-loan"),
        housingRent: num("m-rent"),
        elderlyCare: num("m-elder"),
      };
      const specialSum =
        monthlySpecial.childrenEducation +
        monthlySpecial.infantCare +
        monthlySpecial.continuingEducation +
        monthlySpecial.housingLoanInterest +
        monthlySpecial.housingRent +
        monthlySpecial.elderlyCare;
      const errEl = $("m-error");
      const clearAll = () => {
        ["m-total-gross","m-total-tax","m-total-net","m-eff-rate","m-special-sum","m-deduct-sum"].forEach((id) => ($(id).textContent = "—"));
        document.querySelector<HTMLTableSectionElement>("#m-table tbody")!.replaceChildren();
      };
      // 校验
      if (monthlyGross < 0 || monthlySocial < 0 || monthlyOther < 0 || specialSum < 0) {
        errEl.textContent = "输入金额不能为负数";
        clearAll();
        return;
      }
      if (monthlySocial + specialSum + monthlyOther > monthlyGross + 1e-9 && monthlyGross > 0) {
        errEl.textContent = "扣除项合计大于工资，请检查输入";
      } else {
        errEl.textContent = "";
      }
      $("m-special-sum").textContent = cny(specialSum);
      $("m-deduct-sum").textContent = cny(5000 + monthlySocial + specialSum + monthlyOther);

      if (monthlyGross <= 0) {
        ["m-total-gross","m-total-tax","m-total-net","m-eff-rate"].forEach((id) => ($(id).textContent = "—"));
        document.querySelector<HTMLTableSectionElement>("#m-table tbody")!.replaceChildren();
        return;
      }
      const r = calcUniformYear({ monthlyGross, monthlySocial, monthlySpecial, monthlyOther });
      $("m-total-gross").textContent = cny(r.totalGross);
      $("m-total-tax").textContent = cny(r.totalTax);
      $("m-total-net").textContent = cny(r.totalNet);
      $("m-eff-rate").textContent = `${((r.totalTax / Math.max(1, r.totalGross)) * 100).toFixed(2)}%`;

      const tbody = document.querySelector<HTMLTableSectionElement>("#m-table tbody")!;
      const frag = document.createDocumentFragment();
      for (const row of r.schedule) {
        const tr = document.createElement("tr");
        tr.innerHTML = `<td>${row.month}</td><td>${fmtCny2(row.cumulativeTaxable)}</td><td>${fmtCny2(row.cumulativeTax)}</td><td>${fmtCny2(row.thisMonthWithhold)}</td><td>${fmtCny2(row.netSalary)}</td>`;
        frag.appendChild(tr);
      }
      tbody.replaceChildren(frag);
    }
    document.querySelectorAll<HTMLInputElement>("[id^='m-']").forEach((el) => el.addEventListener("input", renderMonthly));
    renderMonthly();

    // ---------- Tab 2: 年度汇算 ----------
    function renderAnnual(): void {
      const errEl = $("y-error");
      const inputIds = ["y-salary","y-labor","y-author","y-royalty","y-social","y-special","y-other","y-charity","y-withheld"];
      const anyNeg = inputIds.some((id) => num(id) < 0);
      if (anyNeg) {
        errEl.textContent = "输入金额不能为负数";
        ["y-income","y-deduct","y-taxable","y-rate","y-due","y-refund"].forEach((id) => ($(id).textContent = "—"));
        return;
      }
      errEl.textContent = "";
      const r = calcAnnualSettlement({
        salaryAnnual: num("y-salary"),
        laborAnnual: num("y-labor"),
        authorAnnual: num("y-author"),
        royaltyAnnual: num("y-royalty"),
        socialAnnual: num("y-social"),
        specialAnnual: num("y-special"),
        otherAnnual: num("y-other"),
        charityAnnual: num("y-charity"),
        withheldTotal: num("y-withheld"),
      });
      $("y-income").textContent = cny(r.totalIncome);
      $("y-deduct").textContent = cny(r.totalDeduction);
      $("y-taxable").textContent = cny(r.taxable);
      $("y-rate").textContent = `${(r.rate * 100).toFixed(0)}%（速扣 ${r.quickDeduct}）`;
      $("y-due").textContent = cny(r.taxDue);
      const refundEl = $<HTMLElement>("y-refund");
      if (r.refundOrPay > 0.01) {
        refundEl.textContent = `应补 ${cny(r.refundOrPay)}`;
        refundEl.style.color = "var(--c-danger)";
      } else if (r.refundOrPay < -0.01) {
        refundEl.textContent = `应退 ${cny(-r.refundOrPay)}`;
        refundEl.style.color = "var(--c-success)";
      } else {
        refundEl.textContent = `刚好 ¥0`;
        refundEl.style.color = "var(--c-accent)";
      }
    }
    document.querySelectorAll<HTMLInputElement>("[id^='y-']").forEach((el) => el.addEventListener("input", renderAnnual));
    renderAnnual();

    // ---------- Tab 3: 年终奖对比 ----------
    function renderBonus(): void {
      const errEl = $("b-error");
      const bonus = num("b-bonus");
      const base = num("b-base");
      if (bonus < 0 || base < 0) {
        errEl.textContent = "输入金额不能为负数";
        ["b-sep-tax","b-sep-rate","b-com-tax","b-com-inc","b-com-rate","b-recommend","b-saving"].forEach((id) => ($(id).textContent = "—"));
        return;
      }
      errEl.textContent = "";
      const r = calcAnnualBonus({ bonus, baseTaxableNoBonus: base });
      $("b-sep-tax").textContent = cny(r.separate.tax);
      $("b-sep-rate").textContent = `${(r.separate.rate * 100).toFixed(0)}%（速扣 ${r.separate.quickDeduct}）`;
      $("b-com-tax").textContent = cny(r.combined.tax);
      $("b-com-inc").textContent = cny(r.combined.taxIncrement);
      $("b-com-rate").textContent = `${(r.combined.rate * 100).toFixed(0)}%（速扣 ${r.combined.quickDeduct}）`;
      if (r.saving > 0.01) {
        $("b-recommend").textContent = r.recommend === "separate" ? "✅ 单独计税" : "✅ 并入综合所得";
        $("b-saving").textContent = `比另一种方案节省 ${cny(r.saving)}`;
      } else {
        $("b-recommend").textContent = r.recommend === "separate" ? "单独计税" : "并入综合所得";
        $("b-saving").textContent = "两种方案差异极小，按习惯任选";
      }
    }
    document.querySelectorAll<HTMLInputElement>("[id^='b-']").forEach((el) => el.addEventListener("input", renderBonus));
    renderBonus();

    // ---------- Tab 4: 劳务/稿酬 ----------
    function renderIncidental(): void {
      const errEl = $("i-error");
      const amount = num("i-amount");
      if (amount < 0) {
        errEl.textContent = "输入金额不能为负数";
        ["i-taxable","i-tax","i-rate","i-net","i-annual"].forEach((id) => ($(id).textContent = "—"));
        return;
      }
      errEl.textContent = "";
      const type = (document.querySelector<HTMLInputElement>("input[name='i-type']:checked")?.value ?? "labor") as IncidentalIncomeType;
      const r = calcIncidentalPrewith({ amount, type });
      $("i-taxable").textContent = cny(r.taxableForWithhold);
      $("i-tax").textContent = cny(r.withholdTax);
      $("i-rate").textContent = `${(r.rate * 100).toFixed(0)}%${r.quickDeduct ? `（速扣 ${r.quickDeduct}）` : ""}`;
      $("i-net").textContent = cny(amount - r.withholdTax);
      $("i-annual").textContent = cny(r.annualizedIncomeAmount);
    }
    $<HTMLInputElement>("i-amount").addEventListener("input", renderIncidental);
    document.querySelectorAll<HTMLInputElement>("input[name='i-type']").forEach((el) => el.addEventListener("change", renderIncidental));
    renderIncidental();

    // ---------- Tab 5: 经营所得 ----------
    function renderBusiness(): void {
      const errEl = $("o-error");
      const revenue = num("o-revenue");
      const costs = num("o-costs");
      const other = num("o-other");
      const months = num("o-months");
      if (revenue < 0 || costs < 0 || other < 0) {
        errEl.textContent = "输入金额不能为负数";
        ["o-taxable","o-rate","o-quick","o-tax"].forEach((id) => ($(id).textContent = "—"));
        return;
      }
      if (months < 1 || months > 12) {
        errEl.textContent = "经营月数需在 1-12 之间";
        ["o-taxable","o-rate","o-quick","o-tax"].forEach((id) => ($(id).textContent = "—"));
        return;
      }
      errEl.textContent = "";
      const r = calcBusinessIncome({
        annualRevenue: revenue,
        annualCosts: costs,
        annualOtherDeductions: other,
        monthsActive: months,
      });
      $("o-taxable").textContent = cny(r.taxable);
      $("o-rate").textContent = `${(r.rate * 100).toFixed(0)}%`;
      $("o-quick").textContent = cny(r.quickDeduct);
      $("o-tax").textContent = cny(r.tax);
    }
    document.querySelectorAll<HTMLInputElement>("[id^='o-']").forEach((el) => el.addEventListener("input", renderBusiness));
    renderBusiness();
  </script>

