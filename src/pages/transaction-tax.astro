---
import Base from "~/layouts/Base.astro";
---
<Base
  wide
  title="买房税费计算器"
  description="一手房和二手房交易税费计算：契税（首套/二套×140㎡分档）、增值税、个税。按 2025 年 12 月起执行的全国统一新政计算。"
>
  <h1 style="margin-bottom:4px;">买房税费计算器</h1>
  <p style="font-size:13px;margin:0 0 8px;">
    按 2025-12 起执行的全国契税新政计算契税、增值税及附加、个税。一手房通常只涉及契税。
  </p>

  <div class="tabs" role="tablist">
    <button data-tab="new" role="tab" aria-selected="true">一手房（新房）</button>
    <button data-tab="used" role="tab" aria-selected="false">二手房</button>
  </div>

  <div class="split" style="margin-top:8px;">
    <div class="col-input">
      <div class="card compact">
        <h3>买方家庭住房序数</h3>
        <div class="btn-row">
          <input type="radio" name="t-order" id="t-first" value="first" checked />
          <label for="t-first">首套</label>
          <input type="radio" name="t-order" id="t-second" value="second" />
          <label for="t-second">二套</label>
        </div>

        <div class="form-grid" style="margin-top:12px;">
          <label>网签总价（万元）<input id="t-price" type="number" min="1" max="100000" step="1" value="500" /></label>
          <label>建筑面积（㎡）<input id="t-area" type="number" min="1" max="10000" step="1" value="100" /></label>
        </div>

        <div id="t-used-fields" style="display:none;">
          <h3 style="margin-top:12px;">二手房专属</h3>
          <div class="form-grid">
            <label>卖方持有年限
              <select id="t-hold">
                <option value="lt2">不满 2 年</option>
                <option value="btw2_5">满 2 年不满 5 年</option>
                <option value="gte5" selected>满 5 年</option>
              </select>
            </label>
            <label>是否家庭唯一住房
              <select id="t-only">
                <option value="yes" selected>是</option>
                <option value="no">否</option>
              </select>
            </label>
            <label>原值（万元，可选）<input id="t-orig" type="number" min="0" max="100000" step="1" value="" placeholder="留空按 1% 核定" /></label>
          </div>
        </div>
        <p class="error-msg" id="t-error" style="color:var(--c-danger);margin:8px 0 0;min-height:18px;font-size:12px;"></p>
      </div>
    </div>

    <div class="col-result">
      <div class="card compact highlight">
        <div style="font-size:12px;color:var(--c-text-soft);">合计税费</div>
        <div style="font-size:24px;font-weight:600;color:var(--c-accent);" id="r-total">—</div>
      </div>
      <div class="card compact">
        <div class="kv-grid">
          <div><div class="label">契税（买方）</div><div class="value" id="r-contract">—</div></div>
          <div><div class="label">增值税及附加（卖方）</div><div class="value" id="r-vat">—</div></div>
          <div style="grid-column:1/-1;"><div class="label">个税（卖方）</div><div class="value" id="r-income">—</div></div>
        </div>
      </div>
      <div class="card compact">
        <h3>明细</h3>
        <div id="r-breakdown" style="font-size:13px;"></div>
      </div>
    </div>
  </div>

  <details class="card compact" style="margin-top:16px;">
    <summary style="cursor:pointer;font-weight:600;font-size:14px;">计算口径</summary>
    <ul style="font-size:13px;color:var(--c-text-soft);margin:8px 0 0;">
      <li><strong>契税</strong>：2025-12 起，首套 ≤140㎡=1%、&gt;140㎡=1.5%；二套 ≤140㎡=1%、&gt;140㎡=2%（北上广深历史 3% 上限统一为 2%）</li>
      <li><strong>增值税及附加</strong>：二手房持有不满 2 年按 5.3%（含附加）全额征；满 2 年免征（非北上广深；北上广深 90㎡ 以上差额征 5.3%，本计算按多数城市口径=免征）</li>
      <li><strong>个税</strong>：满五唯一免征；其他情况按差额 20% 或核定 1%（多数城市做法）</li>
      <li><strong>未计入</strong>：评估费、按揭手续费、登记费、中介费等</li>
      <li>本结果仅供参考，最终以税务机关核定为准</li>
    </ul>
  </details>

  <p style="font-size:13px;margin-top:12px;">
    继续看：<a href="/mortgage">房贷计算器</a> · <a href="/guides/mortgage-basics">房贷入门</a> · <a href="/guides/prepayment">提前还款指南</a>
  </p>

  <script>
    import { calcTransactionTax, type TransactionType, type HouseOrder, type SellerHoldYears, type SellerOnlyHouse } from "~/lib/tax";
    import { fmtCny } from "~/lib/mortgage";

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const cny = (n: number) => `¥${fmtCny(n)}`;

    // Tab switch (一手 / 二手) — 通过 aria-selected 决定当前 type
    const tabs = document.querySelectorAll<HTMLButtonElement>(".tabs button[data-tab]");
    function getCurrentType(): TransactionType {
      return (document.querySelector<HTMLButtonElement>(".tabs button[aria-selected='true']")?.dataset.tab ?? "new") as TransactionType;
    }
    tabs.forEach((t) =>
      t.addEventListener("click", () => {
        tabs.forEach((x) => x.setAttribute("aria-selected", "false"));
        t.setAttribute("aria-selected", "true");
        render();
      }),
    );

    function render(): void {
      const type = getCurrentType();
      const order = (document.querySelector<HTMLInputElement>("input[name='t-order']:checked")?.value ?? "first") as HouseOrder;
      const priceWan = Number($<HTMLInputElement>("t-price").value);
      const area = Number($<HTMLInputElement>("t-area").value);
      const sellerHoldYears = $<HTMLSelectElement>("t-hold").value as SellerHoldYears;
      const sellerOnlyHouse = $<HTMLSelectElement>("t-only").value as SellerOnlyHouse;
      const origVal = Number($<HTMLInputElement>("t-orig").value);
      const originalPrice = Number.isFinite(origVal) && origVal > 0 ? origVal * 10000 : undefined;
      const errorEl = $<HTMLParagraphElement>("t-error");

      $<HTMLDivElement>("t-used-fields").style.display = type === "used" ? "block" : "none";

      const errs: string[] = [];
      if (!Number.isFinite(priceWan) || priceWan <= 0) errs.push("总价需为正数（万元）");
      if (!Number.isFinite(area) || area <= 0) errs.push("面积需为正数");
      errorEl.textContent = errs.join("；");
      if (errs.length) {
        ["r-contract", "r-vat", "r-income", "r-total"].forEach((id) => ($(id).textContent = "—"));
        const bk = $("r-breakdown");
        bk.innerHTML = "";
        bk.textContent = "请填写有效的总价和面积";
        return;
      }

      const totalPrice = priceWan * 10000;
      const r = calcTransactionTax({ totalPrice, area, order, type, sellerHoldYears, sellerOnlyHouse, originalPrice });
      $("r-contract").textContent = cny(r.contractTax);
      $("r-vat").textContent = type === "new" ? "（不涉及）" : cny(r.valueAddedTax);
      $("r-income").textContent = type === "new" ? "（不涉及）" : cny(r.incomeTax);
      $("r-total").textContent = cny(r.total);

      const bk = $("r-breakdown");
      bk.innerHTML = "";
      if (r.breakdown.length === 0) {
        bk.textContent = "请填写有效的总价和面积";
        return;
      }
      for (const item of r.breakdown) {
        const div = document.createElement("div");
        div.style.cssText = "padding:6px 0;border-bottom:1px solid var(--c-border);";
        div.innerHTML = `<div style="display:flex;justify-content:space-between;gap:8px;"><span>${item.name}</span><span><strong>${cny(item.amount)}</strong>（${item.rate}）</span></div>${item.note ? `<div style="font-size:12px;color:var(--c-text-soft);margin-top:2px;">${item.note}</div>` : ""}`;
        bk.appendChild(div);
      }
    }

    document.querySelectorAll<HTMLElement>("input[name='t-order'],#t-price,#t-area,#t-hold,#t-only,#t-orig").forEach((el) => {
      el.addEventListener("input", render);
      el.addEventListener("change", render);
    });
    render();
  </script>

  <p style="margin-top:24px;padding:12px;background:#fafafa;border:1px solid var(--c-border);border-radius:6px;font-size:12px;color:var(--c-text-soft);">
    <strong>免责声明</strong>：本工具仅为公开税率的演示与教学，不提供税务咨询、税务代理服务。
    各地税务机关执行细则可能略有差异，最终税额以税务机关核定为准。
  </p>
</Base>
