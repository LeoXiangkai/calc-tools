---
import "~/styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  wide?: boolean;
}

const { title, description, canonical, wide = false } = Astro.props;
const pageUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title === "计算工具"
  ? title
  : `${title} - 计算工具`;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: "/", label: "计算工具", brand: true },
  { href: "/mortgage", label: "房贷" },
  { href: "/tax", label: "个税" },
  { href: "/transaction-tax", label: "买房税费" },
  { href: "/compound", label: "复利" },
  { href: "/tax-rate-tables", label: "税率表" },
  { href: "/faq", label: "FAQ" },
  { href: "/about", label: "关于" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="google-adsense-account" content="ca-pub-4449948043133958" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4449948043133958" crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "nav-link",
              { brand: item.brand, active: isActive(item.href) },
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>

    <main>
      {wide ? <slot /> : <div class="reading-inner"><slot /></div>}
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 8px;">
          <a href="/privacy">隐私政策</a>
          <a href="/terms">服务条款</a>
          <a href="/contact">联系方式</a>
        </div>
        <div>计算结果仅供参考，请以银行实际放款为准。</div>
      </div>
    </footer>
  </body>
</html>
